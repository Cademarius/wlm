# =============================================================================
# WLM — variables d'environnement (modèle)
# -----------------------------------------------------------------------------
# Copie ce fichier en `.env.local` pour le DÉVELOPPEMENT et remplis les valeurs
# du projet Supabase de DEV + KkiaPay sandbox.
#
# En PRODUCTION (Vercel) : ne PAS utiliser ce fichier. Définis ces mêmes
# variables dans le dashboard Vercel (Project → Settings → Environment Variables,
# scope « Production ») avec les valeurs du projet Supabase de PROD + KkiaPay live.
#
# Détails et checklist : voir DEPLOYMENT.md
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# DEV  : projet Supabase de développement (données de test).
# PROD : projet Supabase de production (à créer), valeurs mises dans Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # clé "anon public"
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # clé "service_role" — SECRET, serveur uniquement

# --- URL publique de l'app ---------------------------------------------------
# DEV  : http://localhost:3001
# PROD : https://ton-domaine.app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Landing bêta-testeurs (/beta) -------------------------------------------
# Lien d'invitation du groupe WhatsApp (https://chat.whatsapp.com/XXXX).
NEXT_PUBLIC_WHATSAPP_GROUP_URL=

# --- Mode pré-lancement ------------------------------------------------------
# Mettre "1" tant que la livraison OTP (Termii/WhatsApp) n'est pas active :
# toute tentative de connexion affiche "Lancement officiel bientôt" + CTA bêta.
# Repasser à "0" (ou retirer) le jour du lancement pour ouvrir les inscriptions.
NEXT_PUBLIC_PRELAUNCH=

# --- KkiaPay (paiement Mobile Money) -----------------------------------------
# DEV  : clés sandbox + SANDBOX=1
# PROD : clés LIVE + SANDBOX=0 (ou variables absentes)
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET=
NEXT_PUBLIC_KKIAPAY_SANDBOX=1                      # 1 = sandbox (dev), 0 = live (prod)
KKIAPAY_SANDBOX=1                                  # idem côté serveur

# --- Notifications push (VAPID) ----------------------------------------------
# Générer une paire avec `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Administration ----------------------------------------------------------
# Numéros admin au format E.164, séparés par des virgules (ex. +22901xxxxxxxx).
ADMIN_PHONES=

# --- Connexion OTP par WhatsApp/SMS (Supabase Auth Hook « Send SMS ») --------
# Supabase appelle /api/auth/send-otp pour livrer le code (WhatsApp puis SMS).
# Secret fourni par Supabase à la création du hook (format "v1,whsec_...").
SUPABASE_AUTH_HOOK_SECRET=

# --- WhatsApp (API Cloud Meta) : OTP de connexion + invitations virales -------
# Token + ID du numéro WhatsApp Business. Sans config → mode stub (log).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Template de catégorie « Authentication » (code OTP), approuvé par Meta :
WHATSAPP_OTP_TEMPLATE=                           # ex. wlm_otp
WHATSAPP_OTP_LANG=fr                             # langue du template OTP
# Template d'invitation virale (1 variable = l'URL de l'app) :
WHATSAPP_INVITE_TEMPLATE=secret_admirer_invite

# --- SMS : repli OTP + repli invitations --------------------------------------
# Provider choisi automatiquement selon les variables présentes : Termii > Vonage > Twilio.
# NB : ces providers sont appelés par NOTRE endpoint (le hook), pas par Supabase
# directement — donc pas besoin qu'ils soient dans la liste de Supabase.
#
# Termii (RECOMMANDÉ Bénin / Afrique de l'Ouest — inscription qui passe) :
TERMII_API_KEY=
TERMII_FROM=N-Alert                              # sender ID (défaut générique Termii)
# Vonage (alternative) :
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=WLM
# Twilio (alternative) :
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=                                 # ex. +1xxxxxxxxxx (numéro Twilio E.164)
TWILIO_MESSAGING_SERVICE_SID=                    # alternative à TWILIO_SMS_FROM
