# =============================================================================
# WLM — variables d'environnement (modèle)
# -----------------------------------------------------------------------------
# Copie ce fichier en `.env.local` pour le DÉVELOPPEMENT et remplis les valeurs
# du projet Supabase de DEV + KkiaPay sandbox.
#
# En PRODUCTION (Vercel) : ne PAS utiliser ce fichier. Définis ces mêmes
# variables dans le dashboard Vercel (Project → Settings → Environment Variables,
# scope « Production ») avec les valeurs du projet Supabase de PROD + KkiaPay live.
#
# Détails et checklist : voir DEPLOYMENT.md
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# DEV  : projet Supabase de développement (données de test).
# PROD : projet Supabase de production (à créer), valeurs mises dans Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # clé "anon public"
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # clé "service_role" — SECRET, serveur uniquement

# --- URL publique de l'app ---------------------------------------------------
# DEV  : http://localhost:3001
# PROD : https://ton-domaine.app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- KkiaPay (paiement Mobile Money) -----------------------------------------
# DEV  : clés sandbox + SANDBOX=1
# PROD : clés LIVE + SANDBOX=0 (ou variables absentes)
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET=
NEXT_PUBLIC_KKIAPAY_SANDBOX=1                      # 1 = sandbox (dev), 0 = live (prod)
KKIAPAY_SANDBOX=1                                  # idem côté serveur

# --- Notifications push (VAPID) ----------------------------------------------
# Générer une paire avec `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Administration ----------------------------------------------------------
# Numéros admin au format E.164, séparés par des virgules (ex. +22901xxxxxxxx).
ADMIN_PHONES=

# --- WhatsApp / SMS (roadmap #7 — optionnel pour l'instant) -------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_INVITE_TEMPLATE=
